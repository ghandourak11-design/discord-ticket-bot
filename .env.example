# Copy this file to .env and fill in your values

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your Discord application/client ID
CLIENT_ID=your_client_id_here

# Discord user ID that receives DM transcripts when channels are deleted (default: 1456326972631154786)
BOT_OWNER_ID=your_discord_user_id_here

# Base44 API credentials for the /stats command
# BASE44_API_URL is the base URL for your Base44 instance (default: https://app.base44.com)
BASE44_API_URL=https://app.base44.com
# BASE44_APP_ID is your Base44 application ID (e.g. 698bba4e9e06a075e7c32be6)
BASE44_APP_ID=your_app_id_here
# BASE44_API_KEY is your Base44 API authentication key
BASE44_API_KEY=your_base44_api_key_here
