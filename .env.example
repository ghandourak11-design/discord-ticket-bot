# Copy this file to .env and fill in your values

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your Discord application/client ID
CLIENT_ID=your_client_id_here

# Base44 API credentials for the /rank command
# BASE44_API_URL should point to your customers/users entity endpoint, e.g.:
# https://app.base44.com/api/apps/<your-app-id>/entities/Customer
BASE44_API_URL=https://app.base44.com/api/apps/your_app_id_here/entities/Customer
BASE44_API_KEY=your_base44_api_key_here
